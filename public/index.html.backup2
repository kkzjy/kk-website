        <!-- 分隔线 -->
        <div class="post-divider"></div>

        <!-- 文章：关系状态（已隐藏） -->
        <!-- <article class="post-card" id="relationship">
            <h2>关系状态</h2>
            <div class="date">2026-03-01 · 人际关系</div>
            <div class="relationship-list">
